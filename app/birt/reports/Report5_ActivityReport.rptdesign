              <design:query>
                <design:queryText>SELECT DISTINCT CAST(CONCAT(SUBSTRING(`year_month`, 1, 4), '-', SUBSTRING(`year_month`, 5), '-01', ' 23:59:59') AS DATETIME) - INTERVAL 1 DAY AS date, 
DATE_FORMAT(CAST(CONCAT(SUBSTRING(`year_month`, 1, 4), '-', SUBSTRING(`year_month`, 5), '-01', ' 23:59:59') AS DATETIME) - INTERVAL 1 DAY, '%M %Y') AS friendly 
FROM tbl_data_statistics
WHERE `year_month` >= '200701' 
ORDER BY date LIMIT 1,18446744073709551615;</design:queryText>
