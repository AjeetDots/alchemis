              <design:query>
                <design:queryText>SELECT DISTINCT CAST(CONCAT(SUBSTRING(`year_month`, 1, 4), '-', SUBSTRING(`year_month`, 5), '-01', ' 00:00:00') AS DATETIME) AS date, 
DATE_FORMAT(CAST(CONCAT(SUBSTRING(`year_month`, 1, 4), '-', SUBSTRING(`year_month`, 5), '-01', ' 00:00:00') AS DATETIME), '%M %Y') AS friendly 
FROM tbl_data_statistics
ORDER BY date;</design:queryText>
