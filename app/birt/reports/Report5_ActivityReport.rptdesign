            <list-property name="resultSet">
                <structure>
                    <property name="position">1</property>
                    <property name="name">date</property>
                    <property name="nativeName">date</property>
                    <property name="dataType">date-time</property>
                    <property name="nativeDataType">93</property>
                </structure>
                <structure>
                    <property name="position">2</property>
                    <property name="name">friendly</property>
                    <property name="nativeName">friendly</property>
                    <property name="dataType">string</property>
                    <property name="nativeDataType">12</property>
                </structure>
            </list-property>
            <property name="queryText">SELECT DISTINCT CAST(CONCAT(SUBSTRING(`year_month`, 1, 4), '-', SUBSTRING(`year_month`, 5), '-01', ' 23:59:59') AS DATETIME) - INTERVAL 1 DAY AS date, 
DATE_FORMAT(CAST(CONCAT(SUBSTRING(`year_month`, 1, 4), '-', SUBSTRING(`year_month`, 5), '-01', ' 23:59:59') AS DATETIME) - INTERVAL 1 DAY, '%M %Y') AS friendly 
FROM tbl_data_statistics
WHERE `year_month` >= '200701' 
ORDER BY date LIMIT 1,18446744073709551615;</property>
        </oda-data-set>
