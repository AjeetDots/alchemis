            <property name="queryText">SELECT u.id, u.name, count(c.id) AS calls, 
	IFNULL(effectives, 0) AS effectives,
	IFNULL(otes, 0) AS otes, 
	IFNULL(meetings, 0) AS meetings,
	IFNULL(attended, 0) AS attended

FROM tbl_lkp_users AS u 

LEFT JOIN tbl_communications AS c ON u.id = c.user_id 

LEFT JOIN
	(SELECT user_id, count(*) AS effectives 
	FROM tbl_communications 
	WHERE effective = 'effective' AND communication_date >= '2007-01-01 00:00:00' AND communication_date &lt;= '2007-03-01 00:00:00'  
	GROUP BY user_id) AS c2 ON c.user_id = c2.user_id

LEFT JOIN
	(SELECT user_id, count(*) AS otes 
	FROM tbl_communications 
	WHERE ote = '1' AND communication_date >= '2007-01-01 00:00:00' AND communication_date &lt;= '2007-03-01 00:00:00'  
	GROUP BY user_id) AS c3 ON c.user_id = c3.user_id

LEFT JOIN
	(SELECT created_by, count(*) AS meetings 
	FROM tbl_meetings 
	WHERE `date` >= '2007-01-01 00:00:00' AND `date` &lt;= '2007-03-01 00:00:00'  
	GROUP BY created_by) AS m1 ON c.user_id = m1.created_by

LEFT JOIN
	(SELECT created_by, count(*) AS attended 
	FROM tbl_meetings 
	WHERE status_id = 3 AND `date` >= '2007-01-01 00:00:00' AND `date` &lt;= '2007-03-01 00:00:00' 
	GROUP BY created_by) AS m2 ON c.user_id = m2.created_by

WHERE c.communication_date >= '2007-01-01 00:00:00' AND c.communication_date &lt;= '2007-03-01 00:00:00' 

GROUP BY u.id;</property>
