                    <property name="name">otes</property>
                    <property name="nativeName">otes</property>
                    <property name="dataType">decimal</property>
                    <property name="nativeDataType">-5</property>
                </structure>
                <structure>
                    <property name="position">6</property>
                    <property name="name">meetings</property>
                    <property name="nativeName">meetings</property>
                    <property name="dataType">decimal</property>
                    <property name="nativeDataType">-5</property>
                </structure>
                <structure>
                    <property name="position">7</property>
                    <property name="name">attended</property>
                    <property name="nativeName">attended</property>
                    <property name="dataType">decimal</property>
                    <property name="nativeDataType">-5</property>
                </structure>
            </list-property>
            <property name="queryText">SELECT u.id, u.name, count(c.id) AS calls, 
	IFNULL(effectives, 0) AS effectives,
	IFNULL(otes, 0) AS otes, 
	IFNULL(meetings, 0) AS meetings,
	IFNULL(attended, 0) AS attended

FROM tbl_rbac_users AS u 

LEFT JOIN tbl_communications AS c ON u.id = c.user_id 

LEFT JOIN
	(SELECT user_id, count(*) AS effectives 
	FROM tbl_communications 
	WHERE effective = 'effective' AND DATE(communication_date) >= ? AND DATE(communication_date) &lt; ? 
	GROUP BY user_id) AS c2 ON c.user_id = c2.user_id

LEFT JOIN
	(SELECT user_id, count(*) AS otes 
	FROM tbl_communications 
	WHERE ote = '1' AND DATE(communication_date) >= ? AND DATE(communication_date) &lt; ? 
	GROUP BY user_id) AS c3 ON c.user_id = c3.user_id

LEFT JOIN
	(SELECT created_by, count(*) AS meetings 
	FROM tbl_meetings 
	WHERE DATE(`date`) >= ? AND DATE(`date`) &lt; ? 
	GROUP BY created_by) AS m1 ON c.user_id = m1.created_by

LEFT JOIN
	(SELECT created_by, count(*) AS attended 
	FROM tbl_meetings 
	WHERE status_id = 3 AND DATE(`date`) >= ? AND DATE(`date`) &lt; ? 
	GROUP BY created_by) AS m2 ON c.user_id = m2.created_by

WHERE DATE(c.communication_date) >= ? AND DATE(c.communication_date) &lt;= ? 

GROUP BY u.id;</property>
        </oda-data-set>
